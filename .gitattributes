# Force LF line endings for all text files on checkout (Windows host, Linux containers)
# Per CONTEXT.md "Claude's Discretion" — strongly recommended for SK_P (Windows 11 dev,
# Linux container deployment per Phase 8).

* text=auto eol=lf

# Binary file types — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.pdb binary
*.snk binary
*.pfx binary

# Diff settings
*.cs diff=csharp
*.csproj diff=xml
*.props diff=xml
*.targets diff=xml
*.sln merge=union
