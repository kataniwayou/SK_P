{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "MassTransit": "Warning"
    }
  },
  "Service": {
    "Name": "orchestrator",
    "Version": "3.4.0"
  },
  "ConnectionStrings": {
    "Redis": "redis:6379,abortConnect=false,connectTimeout=5000"
  },
  "OpenTelemetry": {
    "Endpoint": "http://otel-collector:4317",
    "Protocol": "grpc"
  },
  "Redis": {
    "KeyPrefix": "skp:"
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "Username": "guest",
    "Password": "guest"
  },
  "ConsoleHealth": {
    "Port": 8081
  },
  "AllowedHosts": "*"
}
