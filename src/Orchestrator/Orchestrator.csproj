<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Orchestrator — the first concrete inheritor of BaseConsole.Core (Phase 19, Stream A).
    A thin Generic-Host shell: composition root + two consumers + two consumer definitions.

    Sdk="Microsoft.NET.Sdk" (NOT .Web) — this is a worker/Generic-Host console, not an MVC web
    app. The ASP.NET Core surface (minimal Kestrel + health checks) needed at runtime for the
    embedded health listener flows TRANSITIVELY via BaseConsole.Core's FrameworkReference
    Microsoft.AspNetCore.App — no FrameworkReference is declared here.

    Hard constraint (D-08): NO ProjectReference to any BaseApi.* project. The orchestrator MUST
    NOT couple to the API (no EF Core / MVC / Npgsql / Swagger attack surface). The only
    ProjectReferences are BaseConsole.Core (infra base) + the leaf Messaging.Contracts assembly.

    Common props (TargetFramework=net8.0, Nullable, ImplicitUsings, LangVersion, AnalysisMode,
    EnforceCodeStyleInBuild, TreatWarningsAsErrors) inherit from Directory.Build.props at the
    repo root — DO NOT redeclare them.

    CPM: NuGet versions are pinned in Directory.Packages.props. NO Version= attribute on any
    PackageReference here.
  -->

  <PropertyGroup>
    <!-- A runnable console host: top-level statements in Program.cs require an executable
         output (CS8805) and the Generic Host RunAsync entry-point produces an .exe. -->
    <OutputType>Exe</OutputType>
    <RootNamespace>Orchestrator</RootNamespace>
    <AssemblyName>Orchestrator</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MassTransit" />
    <PackageReference Include="MassTransit.RabbitMQ" />
    <!-- Quartz scheduler (ORCH-SCHED-01). Quartz.Extensions.Hosting transitively brings
         Quartz + Quartz.Extensions.DependencyInjection — one reference suffices. NO Version= (CPM). -->
    <PackageReference Include="Quartz.Extensions.Hosting" />
  </ItemGroup>

  <ItemGroup>
    <!-- Microsoft.NET.Sdk (worker) does NOT copy appsettings.json by default (unlike .Web).
         The runnable console reads Service/RabbitMq/Redis/ConsoleHealth keys from it at boot,
         so it must land next to the assembly. -->
    <Content Include="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BaseConsole.Core\BaseConsole.Core.csproj" />
    <ProjectReference Include="..\Messaging.Contracts\Messaging.Contracts.csproj" />
  </ItemGroup>

</Project>
