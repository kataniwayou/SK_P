<Project>

  <!--
    Repo-wide MSBuild defaults for the SK_P solution.

    Every csproj under this directory automatically inherits these properties via MSBuild's
    Directory.Build.props convention. Per-project csproj files should NOT redeclare any of
    these — that defeats the single-source-of-truth purpose.

    Per Phase 1 CONTEXT.md decisions:
      D-01: Shared MSBuild settings live ONLY in this file at repo root.
      D-02: TreatWarningsAsErrors=true globally — Phase 1 SC#1 "zero warnings" is enforced
            at compile time, not via post-hoc review.
      D-03: Strictness bundle (Nullable, ImplicitUsings, LangVersion, AnalysisMode,
            EnforceCodeStyleInBuild) — surface compiler/analyzer/style issues as errors.
      D-04 (Phase 1 deferral, AMENDED by Phase 6 D-11): Mapperly diagnostic codes are
            promoted to errors SOLUTION-WIDE via the <WarningsAsErrors> entry below — NOT
            per-csproj as the original Phase 1 D-04 anticipated. The codes are RMG-prefixed
            (RMG007/RMG012/RMG020/RMG089), NOT MP-prefixed. Mapperly's actual analyzer uses
            RMG codes exclusively; the original CONTEXT documentation used a non-existent
            MP-prefix that was corrected via Phase 6 RESEARCH A-01 amendment.

    Central NuGet package management is configured in Directory.Packages.props (sibling
    file). Do NOT duplicate the central-package-management property here (per D-06) —
    it belongs only in Directory.Packages.props.
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AnalysisMode>latest</AnalysisMode>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Phase 6 D-11/D-12 (codes corrected MP→RMG per RESEARCH A-01).
         RMG089 (Info) is the ONLY load-bearing entry here — TreatWarningsAsErrors=true
         above only catches Warning/Error severities, so RMG089 needs the explicit list.
         RMG007 (Error default), RMG012/RMG020 (Warning default) are listed for
         defense-in-depth + auditability per D-12. -->
    <WarningsAsErrors>$(WarningsAsErrors);RMG007;RMG012;RMG020;RMG089</WarningsAsErrors>
  </PropertyGroup>

</Project>
