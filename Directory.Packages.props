<Project>

  <!--
    Central Package Management (CPM) for the SK_P solution.

    Every NuGet package version used across BaseApi.Core, BaseApi.Service, and BaseApi.Tests
    is pinned HERE. Per-project csproj files declare <PackageReference Include="..." /> with
    NO Version attribute — CPM resolves the version from this table.

    Per Phase 1 CONTEXT.md decisions:
      D-05: Front-load ALL 22 STACK-verified pins in Phase 1. Each subsequent phase only
            adds <PackageReference> entries; the version is already pinned here.
      D-06: <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally> belongs
            ONLY in this file. Do NOT duplicate it in Directory.Build.props.
      D-07: Source-generator packages require asset-control attributes in CONSUMER csproj
            (not here). See conventions below.

    ── SOURCE-GENERATOR / DESIGN-TIME PACKAGE CONVENTIONS ─────────────────────────────────
    When a csproj references one of the packages below, it MUST add the listed attributes
    to its <PackageReference> entry (CPM does not control these attributes — they live in
    the consumer csproj). Forgetting them is a frequent footgun:

      Riok.Mapperly:
        <PackageReference Include="Riok.Mapperly"
                          PrivateAssets="all"
                          ExcludeAssets="runtime" />
        Why: source generator runs at build time only. PrivateAssets="all" prevents the
        analyzer from leaking to downstream consumers. ExcludeAssets="runtime" prevents a
        runtime DLL load that's never used.

      Microsoft.EntityFrameworkCore.Design:
        <PackageReference Include="Microsoft.EntityFrameworkCore.Design"
                          PrivateAssets="all" />
        Why: this is `dotnet ef` tooling — it should never flow as a transitive dependency.

    Versions are aligned with .NET 8.0.421 runtime (8.0.27) where applicable. EF Core and
    Microsoft.AspNetCore.Mvc.Testing patches are kept in lockstep with the runtime patch.
    See .planning/research/STACK.md for the full provenance and verification table.
    ────────────────────────────────────────────────────────────────────────────────────────
  -->

  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- EF Core 8 — keep .NET runtime + EF Core in lockstep -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Version="8.0.27" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.27" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Relational" Version="8.0.27" />
    <!-- Plan 19-03 (test-only): EF Core InMemory provider lets OrchestrationServicePublishTests
         drive the REAL OrchestrationService.StartAsync existence check against a seeded
         WorkflowEntity without a real Postgres. The provider ignores relational annotations
         (xmin xid column type, snake_case naming) so the BaseDbContext model builds cleanly. -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore.InMemory" Version="8.0.27" />
    <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="8.0.10" />
    <!-- Npgsql 8.0.9 is the latest 8.x release (Npgsql skipped 8.0.10; the 9.x line followed).
         Npgsql.EntityFrameworkCore.PostgreSQL 8.0.10's nuspec declares Npgsql >= 8.0.5; pinning
         8.0.9 satisfies that constraint AND preserves runtime binary compatibility with the
         8.x provider. Pinning Npgsql 9.0.0 (the original Plan 04-01 Task 1 fix-forward) was
         WRONG: the EFCore provider 8.0.10 was built against Npgsql 8.x internals
         (e.g., Npgsql.Internal.HackyEnumTypeMapping) that 9.0.0 removed, causing
         TypeLoadException at runtime when the EF provider tries to bootstrap the type
         mapping. Surfaced by Plan 04-02 verification battery; documented as fix(04-01)
         per Phase 1/2/3 deviation convention. -->
    <PackageVersion Include="Npgsql" Version="8.0.9" />
    <PackageVersion Include="EFCore.NamingConventions" Version="8.0.3" />

    <!-- Mapping (source-gen) — PrivateAssets/ExcludeAssets go in CONSUMER csproj -->
    <PackageVersion Include="Riok.Mapperly" Version="4.3.1" />

    <!-- Validation -->
    <PackageVersion Include="FluentValidation" Version="12.1.1" />
    <PackageVersion Include="FluentValidation.DependencyInjectionExtensions" Version="12.1.1" />

    <!-- Observability — core + hosting + OTLP exporter pinned together -->
    <PackageVersion Include="OpenTelemetry" Version="1.15.3" />
    <PackageVersion Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
    <PackageVersion Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    <!-- Instrumentation packages version on their own cadence (currently 1.15.0) -->
    <PackageVersion Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.15.0" />
    <PackageVersion Include="OpenTelemetry.Instrumentation.Http" Version="1.15.0" />
    <!-- Phase 5 (CONTEXT.md D-16): process.runtime.dotnet.* metrics (GC/threadpool/exceptions) -->
    <PackageVersion Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.0" />
    <!-- Phase 5 (CONTEXT.md D-05 corrected to bare .AddNpgsql()): Npgsql DB tracing.
         Declares dep `Npgsql >= 8.0.4` — satisfied by Phase 4 fix-forward pin 8.0.9. -->
    <PackageVersion Include="Npgsql.OpenTelemetry" Version="8.0.4" />

    <!-- Domain validators -->
    <PackageVersion Include="JsonSchema.Net" Version="9.2.1" />
    <PackageVersion Include="Cronos" Version="0.13.0" />

    <!-- v3.4.0 / Phase 23 — Quartz scheduler (ORCH-SCHED-01). Both pinned for auditability
         even though Quartz.Extensions.Hosting transitively brings Quartz (repo CPM convention).
         Exact version 3.18.1 (no floating range) verified against nuget.org (T-23-03 mitigation). -->
    <PackageVersion Include="Quartz" Version="3.18.1" />
    <PackageVersion Include="Quartz.Extensions.Hosting" Version="3.18.1" />

    <!-- Health checks -->
    <PackageVersion Include="AspNetCore.HealthChecks.NpgSql" Version="9.0.0" />
    <!-- Phase 5 (CONTEXT.md D-07): UIResponseWriter.WriteHealthCheckUIResponse JSON body writer -->
    <PackageVersion Include="AspNetCore.HealthChecks.UI.Client" Version="9.0.0" />

    <!-- HTTP — API versioning + Swagger (REQ HTTP-15, HTTP-16) -->
    <PackageVersion Include="Asp.Versioning.Http" Version="8.1.0" />
    <PackageVersion Include="Swashbuckle.AspNetCore" Version="6.9.0" />
    <!-- Phase 7 RESEARCH A-01: Asp.Versioning.Mvc is the controllers-correct package
         (CONTEXT D-17's "Asp.Versioning.Http" is the brand-name reference; the actual
         NuGet for [ApiController]+[ApiVersion] attribute resolution is Asp.Versioning.Mvc,
         which transitively pulls Asp.Versioning.Http). ApiExplorer is required for
         SubstituteApiVersionInUrl + GroupNameFormat. The existing Asp.Versioning.Http 8.1.0
         pin is RETAINED for CPM explicit-pin auditability (RESEARCH Open Q4). -->
    <PackageVersion Include="Asp.Versioning.Mvc" Version="8.1.0" />
    <PackageVersion Include="Asp.Versioning.Mvc.ApiExplorer" Version="8.1.0" />

    <!-- Tests -->
    <PackageVersion Include="Microsoft.AspNetCore.Mvc.Testing" Version="8.0.27" />
    <!-- Phase 7 RESEARCH Pitfall 9: NSubstitute (post-Moq SponsorLink). Used by
         tests/BaseApi.Tests for SC#2 6-step ordering proof via Received.InOrder. -->
    <PackageVersion Include="NSubstitute" Version="5.3.0" />
    <PackageVersion Include="xunit.v3" Version="3.2.2" />
    <PackageVersion Include="xunit.v3.assert" Version="3.2.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
    <!-- Reserved for Phase 8 integration tests (TEST-01..06); currently unreferenced. -->
    <PackageVersion Include="Testcontainers.PostgreSql" Version="4.11.0" />

    <!-- Microsoft.Extensions.* family — versions on own cadence (Phase 3: FakeTimeProvider) -->
    <PackageVersion Include="Microsoft.Extensions.TimeProvider.Testing" Version="8.10.0" />

    <!-- v3.3.0 / Phase 12 — Redis L2 projection client (CPM pin, INFRA-REDIS-03). -->
    <PackageVersion Include="StackExchange.Redis" Version="2.13.1" />

    <!-- MassTransit 8.5.5 is the last Apache-2.0 line. v9+ is COMMERCIAL: organizations over
         $1M revenue pay a $400/mo minimum; v8.x stays open-source + security-patched through
         end-2026. Do NOT bump to 9.x without a license decision. No PackageReference yet
         (Phase 17 = CPM pin only; the publisher/consumer wiring lands Phase 18+). -->
    <PackageVersion Include="MassTransit" Version="8.5.5" />
    <PackageVersion Include="MassTransit.RabbitMQ" Version="8.5.5" />
  </ItemGroup>

</Project>
